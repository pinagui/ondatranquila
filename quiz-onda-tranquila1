<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #FAF7F2;
    --warm-white: #FFFDF9;
    --deep: #1C1A17;
    --brown: #3D2E1E;
    --accent: #C4622D;
    --accent-light: #E8845A;
    --muted: #8A7968;
    --border: #E8E0D4;
    --progress-bg: #EDE6DA;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--deep);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* TOPBAR */
  .topbar {
    width: 100%;
    background: var(--brown);
    color: #F5ECD7;
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* HEADER */
  .header {
    width: 100%;
    max-width: 680px;
    padding: 36px 24px 0;
    text-align: center;
  }
  .header .badge {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 20px;
  }
  .header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(24px, 5.5vw, 36px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--brown);
    margin-bottom: 16px;
  }
  .header h1 em {
    font-style: italic;
    color: var(--accent);
  }
  .header .subtitle {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 32px;
  }

  /* CARD */
  .card-wrap {
    width: 100%;
    max-width: 680px;
    padding: 16px 24px 8px;
  }
  .card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow: 0 4px 32px rgba(60,40,20,0.07);
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    top:0; left:0; right:0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
  }

  /* SYMPTOMS CHECKLIST */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(18px, 4vw, 22px);
    font-weight: 600;
    color: var(--brown);
    line-height: 1.35;
    margin-bottom: 20px;
  }
  .checklist {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 8px;
  }
  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 13px 16px;
    background: #FFF8F4;
    border: 1px solid #F5C4A8;
    border-radius: 12px;
    font-size: 14px;
    color: var(--deep);
    line-height: 1.45;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .check-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .check-icon {
    width: 22px; height: 22px;
    background: var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
    color: white;
    font-weight: 700;
    margin-top: 1px;
  }

  /* DIVIDER */
  .divider {
    width: 100%;
    max-width: 680px;
    padding: 0 24px;
    margin: 4px 0;
  }
  .divider-line {
    border: none;
    border-top: 1px solid var(--border);
  }

  /* EXPLANATION CARD */
  .explain-card {
    background: linear-gradient(135deg, #FFF8F3, #FFF0E6);
    border: 1px solid #F5C4A8;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 0;
  }
  .explain-card p {
    font-size: 15px;
    color: var(--deep);
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .explain-card p:last-child { margin-bottom: 0; }
  .explain-card strong { color: var(--brown); }
  .explain-card em { color: var(--accent); font-style: normal; font-weight: 600; }

  /* DOCTOR CARD */
  .doctor-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: #F5F0E8;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 0;
  }
  .doctor-photo {
    width: 72px; height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 3px solid var(--accent);
  }
  .doctor-info { flex: 1; }
  .doctor-name { font-weight: 700; font-size: 15px; color: var(--brown); margin-bottom: 2px; }
  .doctor-role { font-size: 12px; color: var(--accent); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 10px; }
  .doctor-quote { font-size: 14px; color: var(--deep); line-height: 1.6; font-style: italic; }

  /* WHAT YOU'LL DISCOVER */
  .discover-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .discover-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .discover-num {
    width: 28px; height: 28px;
    background: var(--brown);
    color: #F5ECD7;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .discover-text {
    flex: 1;
  }
  .discover-text strong {
    display: block;
    font-size: 15px;
    color: var(--brown);
    font-weight: 600;
    margin-bottom: 3px;
  }
  .discover-text span {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* URGENCY BAR */
  .urgency {
    background: #FFF8EC;
    border: 1px solid #F5DFA8;
    border-radius: 10px;
    padding: 13px 18px;
    font-size: 13px;
    color: #8A6820;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    line-height: 1.5;
  }

  /* CTA */
  .cta-wrap { text-align: center; }
  .btn-cta {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, var(--accent), #D4703A);
    color: white;
    border: none;
    border-radius: 14px;
    padding: 20px 32px;
    font-size: 17px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 6px 24px rgba(196,98,45,0.35);
    text-decoration: none;
    margin-bottom: 12px;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }
  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(196,98,45,0.45);
  }
  .cta-note {
    font-size: 12px;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  /* SOCIAL PROOF */
  .testimonial-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .testimonial {
    background: white;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
  }
  .testimonial-text {
    font-size: 14px;
    color: var(--deep);
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 12px;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .testimonial-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--progress-bg);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .testimonial-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--brown);
  }
  .testimonial-meta {
    font-size: 12px;
    color: var(--muted);
  }
  .stars { color: #E8A430; font-size: 13px; letter-spacing: 1px; }

  /* SPACING HELPERS */
  .gap-sm { height: 16px; }
  .gap-md { height: 24px; }

  /* SECTION CARDS */
  .section-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 32px rgba(60,40,20,0.07);
    position: relative;
    overflow: hidden;
  }
  .section-card::before {
    content: '';
    position: absolute;
    top:0; left:0; right:0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
  }

  /* FOOTER */
  .footer {
    width: 100%;
    max-width: 680px;
    padding: 8px 24px 36px;
    text-align: center;
    font-size: 11px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }
  .delay-1 { animation-delay: 0.15s; }
  .delay-2 { animation-delay: 0.3s; }
  .delay-3 { animation-delay: 0.45s; }
  .delay-4 { animation-delay: 0.6s; }
  .delay-5 { animation-delay: 0.75s; }

  /* PULSE CTA */
  @keyframes pulse-shadow {
    0%, 100% { box-shadow: 0 6px 24px rgba(196,98,45,0.35); }
    50%       { box-shadow: 0 8px 36px rgba(196,98,45,0.55); }
  }
  .btn-cta { animation: pulse-shadow 2.5s ease-in-out infinite; }
  .btn-cta:hover { animation: none; }

  @media(max-width:500px){
    .section-card, .card { padding: 26px 20px; }
    .doctor-card { flex-direction: column; align-items: center; text-align: center; }
  }
</style>
</head>
<body>

<div class="topbar">🔒 Presentación gratuita con la Dra. Isabel Martínez · Neuropediatra</div>

<!-- HERO HEADER -->
<div class="header fade-up">
